# justfile — Verisim research prototype build/test recipes

# Run the full test suite via Pkg.test()
test:
    julia --project=. -e 'using Pkg; Pkg.test()'

# Run a single test file standalone (flat-include scaffold)
test-file FILE:
    julia --project=. test/{{FILE}}

# Run the KRLAdapter dogfood demo
demo:
    julia --project=. examples/krladapter_integration.jl

# Drop into an interactive session with the package pre-loaded
repl:
    julia --project=. -e 'using Verisim; import KnotTheory'

# Check package integrity
check:
    julia --project=. -e 'using Pkg; Pkg.instantiate(); Pkg.resolve(); Pkg.status()'

# Build the Zig CLI (debug)
cli-build:
    cd ffi/zig && zig build

# Build the Zig CLI (release, with safety checks)
cli-build-release:
    cd ffi/zig && zig build -Doptimize=ReleaseSafe

# Run Zig CLI unit tests (verdict parser + protocol invariants)
cli-test:
    cd ffi/zig && zig build test --summary all

# Run a VCL query through the full CLI → Julia pipeline
# Usage: just cli-query "PROOF INTEGRITY FOR abababababababababababababababababab"
cli-query QUERY:
    echo '{{QUERY}}' | VERISIM_PACKAGE_PATH=. ffi/zig/zig-out/bin/verisim
