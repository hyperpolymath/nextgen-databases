# Lith Studio - Build commands (Gossamer backend)

# Default recipe
default:
    @just --list

# Setup development environment
setup:
    @echo "Setting up Lith Studio..."
    deno cache src/main.tsx
    cargo build
    just rescript-build

# Build ReScript files
rescript-build:
    deno run -A npm:rescript build

# Watch ReScript files
rescript-watch:
    deno run -A npm:rescript build -w

# Bundle frontend for production
bundle:
    just rescript-build
    deno run -A npm:esbuild src/main.tsx --bundle --outfile=dist/app.js --format=esm --jsx=automatic --loader:.js=jsx

# Development mode with hot reload
dev:
    just bundle
    cargo run

# Build for production
build:
    just bundle
    cargo build --release

# Type check Lean 4 proofs
check-proofs:
    cd ../gqldt && lake build

# Format code
fmt:
    deno fmt src/*.tsx
    cargo fmt

# Lint
lint:
    cargo clippy

# Clean build artifacts
clean:
    rm -rf dist/app.js
    rm -rf src/*.res.js
    cargo clean
